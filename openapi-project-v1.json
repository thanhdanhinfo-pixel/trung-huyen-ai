{
  "openapi": "3.1.0",
  "info": {
    "title": "PROJECT_GPT",
    "version": "1.1.0",
    "description": "Specialized GPT Action schema for project execution and practical delivery. Shared startup plus workspace and execution actions."
  },
  "servers": [
    {
      "url": "https://trung-huyen-ai-779121307308.asia-southeast1.run.app"
    }
  ],
  "paths": {
    "/system/khoi-dong": {
      "get": {
        "operationId": "startupSystem",
        "summary": "Khởi động hệ thống",
        "description": "Load Startup Memory Pack, checkpoint, governance, global memory and next actions.",
        "responses": {
          "200": {
            "description": "Startup state loaded",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": {}, "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/system/next-actions": {
      "get": {
        "operationId": "getNextActions",
        "summary": "Get next actions",
        "responses": {
          "200": {
            "description": "Next actions",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/workspace/load": {
      "get": {
        "operationId": "loadWorkspace",
        "summary": "Load workspace",
        "responses": {
          "200": {
            "description": "Workspace loaded",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/execute": {
      "post": {
        "operationId": "executeTask",
        "summary": "Execute project task",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["goal"],
                "properties": {
                  "goal": { "type": "string" },
                  "tasks": { "type": "array", "items": { "type": "object", "additionalProperties": true }, "default": [] },
                  "approved": { "type": "boolean", "default": false }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Execution result",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    }
  }
}
