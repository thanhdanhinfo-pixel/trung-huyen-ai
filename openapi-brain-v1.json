{
  "openapi": "3.1.0",
  "info": {
    "title": "BRAIN_GPT",
    "version": "1.1.0",
    "description": "Specialized GPT Action schema for BỘ NÃO GỐC NGUYỄN DUY TRUNG. Shared startup plus founder knowledge and Drive/RAG access."
  },
  "servers": [
    {
      "url": "https://trung-huyen-ai-779121307308.asia-southeast1.run.app"
    }
  ],
  "paths": {
    "/system/khoi-dong": {
      "get": {
        "operationId": "startupSystem",
        "summary": "Khởi động hệ thống",
        "description": "Load Startup Memory Pack, checkpoint, governance, global memory and next actions.",
        "responses": {
          "200": {
            "description": "Startup state loaded",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/system/memory-pack": {
      "get": {
        "operationId": "getMemoryPack",
        "summary": "Get Governance Memory Pack",
        "responses": {
          "200": {
            "description": "Memory pack",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/system/global-memory": {
      "get": {
        "operationId": "getGlobalMemory",
        "summary": "Get global memory",
        "responses": {
          "200": {
            "description": "Global memory",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/mcp/read-drive-path": {
      "get": {
        "operationId": "readDrivePath",
        "summary": "Read Google Drive file by logical path",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Drive file content",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/mcp/test-search": {
      "get": {
        "operationId": "searchKnowledge",
        "summary": "Search knowledge",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "default": "Hệ quan sát" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 3 }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    }
  }
}
