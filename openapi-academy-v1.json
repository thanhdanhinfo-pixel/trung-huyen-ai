{
  "openapi": "3.1.0",
  "info": {
    "title": "ACADEMY_GPT",
    "version": "1.3.0",
    "description": "Academy GPT Actions schema. Focuses on learning programs, courses, lessons, roadmap, progress, quizzes, and Academy knowledge."
  },
  "servers": [
    {
      "url": "https://trung-huyen-ai-779121307308.asia-southeast1.run.app"
    }
  ],
  "paths": {
    "/system/khoi-dong": {
      "get": {
        "operationId": "startupSystem",
        "summary": "Khởi động hệ thống trước khi học tập",
        "responses": { "200": { "description": "Startup state" } }
      }
    },
    "/academy/courses": {
      "get": {
        "operationId": "listAcademyCourses",
        "summary": "List Academy courses",
        "responses": { "200": { "description": "Course list" } }
      }
    },
    "/academy/modules": {
      "get": {
        "operationId": "listAcademyModules",
        "summary": "List Academy modules",
        "parameters": [
          {
            "name": "course_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Module list" } }
      }
    },
    "/academy/lessons": {
      "get": {
        "operationId": "listAcademyLessons",
        "summary": "List Academy lessons",
        "parameters": [
          {
            "name": "module_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Lesson list" } }
      }
    },
    "/academy/search": {
      "get": {
        "operationId": "searchAcademyKnowledge",
        "summary": "Search Academy knowledge",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Search results" } }
      }
    },
    "/academy/roadmap": {
      "get": {
        "operationId": "getAcademyRoadmap",
        "summary": "Get learning roadmap",
        "parameters": [
          {
            "name": "goal",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Learning roadmap" } }
      }
    },
    "/academy/quiz": {
      "post": {
        "operationId": "createAcademyQuiz",
        "summary": "Create quiz from lesson or topic",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "topic": { "type": "string" },
                  "lesson_id": { "type": "string" },
                  "difficulty": { "type": "string" }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": { "200": { "description": "Generated quiz" } }
      }
    },
    "/academy/progress": {
      "get": {
        "operationId": "getAcademyProgress",
        "summary": "Get learning progress",
        "parameters": [
          {
            "name": "learner_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Learning progress" } }
      }
    },
    "/academy/save-learning-note": {
      "post": {
        "operationId": "saveLearningNote",
        "summary": "Save Academy learning note",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": { "type": "string" },
                  "course_id": { "type": "string" },
                  "lesson_id": { "type": "string" }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": { "200": { "description": "Learning note saved" } }
      }
    }
  }
}
