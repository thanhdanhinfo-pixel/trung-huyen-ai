{
  "openapi": "3.1.0",
  "info": {
    "title": "TRUNG_HUYEN_AI_OS_DRIVE",
    "version": "3.2.0",
    "description": "Clean Drive Actions for TRUNG_HUYEN_AI_OS"
  },
  "servers": [
    {
      "url": "https://trung-huyen-ai-779121307308.asia-southeast1.run.app"
    }
  ],
  "paths": {
    "/mcp/ping": {
      "get": {
        "operationId": "pingMcp",
        "summary": "Ping MCP runtime",
        "responses": {
          "200": { "description": "Alive" }
        }
      }
    },
    "/mcp/read-file": {
      "get": {
        "operationId": "readFile",
        "summary": "Read a file from GitHub repository",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "File content" }
        }
      }
    },
    "/mcp/list-directory": {
      "get": {
        "operationId": "listDirectory",
        "summary": "List repository directory",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Directory listing" }
        }
      }
    },
    "/mcp/search-code": {
      "get": {
        "operationId": "searchCode",
        "summary": "Search code in repository",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Search result" }
        }
      }
    },
    "/mcp/read-drive-path": {
      "get": {
        "operationId": "readDrivePath",
        "summary": "Read Google Drive file by logical path",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Drive file content" }
        }
      }
    }
  }
}
