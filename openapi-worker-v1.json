{
  "openapi": "3.1.0",
  "info": {
    "title": "WORKER_GPT",
    "version": "1.1.0",
    "description": "Specialized GPT Action schema for worker execution and workflow status. Shared startup plus workflow and execution actions."
  },
  "servers": [
    {
      "url": "https://trung-huyen-ai-779121307308.asia-southeast1.run.app"
    }
  ],
  "paths": {
    "/system/khoi-dong": {
      "get": {
        "operationId": "startupSystem",
        "summary": "Khởi động hệ thống",
        "description": "Load Startup Memory Pack, checkpoint, governance, global memory and next actions.",
        "responses": {
          "200": {
            "description": "Startup state loaded",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": {}, "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/system/tool-health": {
      "get": {
        "operationId": "getToolHealth",
        "summary": "Get tool health",
        "responses": {
          "200": {
            "description": "Tool health",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/developer/workflow/tasks": {
      "get": {
        "operationId": "getWorkflowTasks",
        "summary": "Get workflow tasks",
        "responses": {
          "200": {
            "description": "Workflow tasks",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/developer/workflow/status": {
      "get": {
        "operationId": "getWorkflowStatus",
        "summary": "Get workflow status",
        "responses": {
          "200": {
            "description": "Workflow status",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/execute": {
      "post": {
        "operationId": "executeTask",
        "summary": "Execute worker task",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["goal"],
                "properties": {
                  "goal": { "type": "string" },
                  "tasks": { "type": "array", "items": { "type": "object", "additionalProperties": true }, "default": [] },
                  "approved": { "type": "boolean", "default": false }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Execution result",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    }
  }
}
